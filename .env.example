APP_ENV=development
SECRET_KEY=change-this-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

REGOLO_API_KEY=

APP_HOST=127.0.0.1
APP_PORT=5001
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_DIR=app/logs

SANDBOX_IMAGE=talktomyexcel-sandbox:latest
SANDBOX_TIMEOUT=120
PYTHON_SANDBOX_IMAGE=talktomyexcel-sandbox:latest
PYTHON_SANDBOX_TIMEOUT=20
PYTHON_SANDBOX_MEMORY=768m
MAX_UPLOAD_MB=50

# Optional temporary public demo workspaces.
DEMO_ENABLED=false
DEMO_TIMEOUT_MINUTES=30

# Optional character-based chunking for Chroma semantic indexing.
# 0 keeps one embedding document per spreadsheet row.
# After changing either value, restart and rebuild the full semantic index.
SEMANTIC_CHUNK_SIZE=0
SEMANTIC_CHUNK_OVERLAP=0
